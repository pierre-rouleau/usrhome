# Sourced script: do-extend-manpath  -*- mode: sh; -*-
#
# Purpose   : Set/extend MANPATH from manpath output; safe to re-source.
# Created   : Sunday, May 26 2024.
# Author    : Pierre Rouleau <prouleau001@gmail.com>
# Time-stamp: <2026-04-24 12:49:57 EDT, updated by Pierre Rouleau>
# ----------------------------------------------------------------------------

# Module Description
# ------------------
#
# Prepare extending the list of directories searched by the man utility.
# Source (include) this file inside other sourced files before adding to the
# MANPATH value.
#
# On some systems MANPATH is set to an invalid value of ":".
# In the man utility, a leading or trailing colon in MANPATH tells the system
# to include the default system manual paths in addition to whatever custom
# paths you've added.
#
# That, however only works for the man utility.  It does not allow other tools
# to inspect the list of directories holding man files as an explicit set of
# directories listed inside the value of the MANPATH environment variable
# does.  This is why the colon is removed and replaced by the list printed by
# the manpath utility.
#
#
# If your system has an extra set of man directories somewhere outside of the
# standard places, identify them inside the MANPATH_EXTRA_BEFORE or
# MANPATH_EXTRA_AFTER variables.  The value of MANPATH_EXTRA_BEFORE is
# pre-pended to the list and the value of MANPATH_EXTRA_AFTER is appended to
# the list.
#
# Usage:
#  - Source it with: . "$USRHOME_DIR/ibin/do-extend-manpath"
#  - To print info : . "$USRHOME_DIR/ibin/do-extend-manpath" verbose
#
# To activate the verbose output you may also set the MANPATH_SHOW_IF_MODIFIED
# environment variable to the value: true
#
# ----------------------------------------------------------------------------
# Code
# ----
#
# Code strategy

# - Always compute the fresh manpath/manpath -g output, regardless of whether
#   MANPATH is already set.
# - If MANPATH is empty/invalid, set it from that fresh output.
# - If MANPATH is already set, merge any new directories from the fresh output
#   that are not yet present — making re-sourcing after a PATH extension fully
#   effective.
# - Make MANPATH_EXTRA_BEFORE / MANPATH_EXTRA_AFTER idempotent (check
#   component by component before prepending/appending) so repeated sourcing
#   never creates duplicates.
# - Unset all temporary variables to avoid polluting the shell environment.
# - use _dxm_ prefix (for: Do eXtend Manpath) in internal variable.
#
# POSIX compliant techniques used:
# -  ${VAR:+word}    Expansion evaluates to word only when var is set and
#                    non-empty, otherwise to nothing.
# -  ${VAR#pattern}: Removes the shortest match of pattern from the beginning of
#                    the string.
# -  ${VAR%pattern}: Removes the shortest match from the end.

# --- 1. Obtain the freshest possible manpath list from the system.
#        manpath(1) scans PATH, so this may grow as PATH is extended.
#        - Ensure that manpath extracts the system list by temporary
#          setting MANPATH to a single colon to force manpath utility
#          to return the system's list of man directories.

_dxm_manpath="$MANPATH"
MANPATH=":"
if _dxm_fresh_manpath="$(manpath -g 2>/dev/null)"; then
    :   #  Do nothing, it's already done.
else
    # For cases where the -g option is not available do it without.
    _dxm_fresh_manpath="$(manpath)"
fi
MANPATH=

# --- 2. Initialize or extend MANPATH.
if [ -z "$_dxm_manpath" ] || [ "$_dxm_manpath" = ":" ]; then
    # Not set (or set to special bare colon): seed from the fresh list.
    MANPATH="$_dxm_fresh_manpath"
else
    # Strip stray leading/trailing colons from MANPATH.
    MANPATH="${MANPATH#:}"; MANPATH="${MANPATH%:}"

    # Already set: merge directories that manpath now knows about but that are
    # not yet in MANPATH (e.g. because PATH grew since the last sourcing).
    _dxm_IFS_save="$IFS"
    IFS=':'
    for _dxm_dir in $_dxm_fresh_manpath; do
        [ -z "$_dxm_dir" ] && continue

        case ":${MANPATH}:" in
            *":${_dxm_dir}:"*) ;;          # already present – skip
            *)
                MANPATH="${MANPATH:+${MANPATH}:}${_dxm_dir}"
                ;;
        esac
    done
    IFS="$_dxm_IFS_save"
fi

# --- 3. Prepend MANPATH_EXTRA_BEFORE (idempotent, component by component).
if [ -n "$MANPATH_EXTRA_BEFORE" ]; then
    _dxm_IFS_save="$IFS"
    IFS=':'
    # Iterate in reverse so prepending keeps the declared order.
    # Build a reversed list first.
    _dxm_rev=""
    for _dxm_dir in $MANPATH_EXTRA_BEFORE; do
        [ -z "$_dxm_dir" ] && continue
        _dxm_rev="${_dxm_dir}${_dxm_rev:+:$_dxm_rev}"
    done
    for _dxm_dir in $_dxm_rev; do
        [ -z "$_dxm_dir" ] && continue
        case ":${MANPATH}:" in
            *":${_dxm_dir}:"*) ;;
            *)
                MANPATH="${_dxm_dir}${MANPATH:+:${MANPATH}}"
                ;;
        esac
    done
    IFS="$_dxm_IFS_save"
fi

# --- 4. Append MANPATH_EXTRA_AFTER (idempotent, component by component).
if [ -n "$MANPATH_EXTRA_AFTER" ]; then
    _dxm_IFS_save="$IFS"
    IFS=':'
    for _dxm_dir in $MANPATH_EXTRA_AFTER; do
        [ -z "$_dxm_dir" ] && continue
        case ":${MANPATH}:" in
            *":${_dxm_dir}:"*) ;;
            *)
                MANPATH="${MANPATH:+${MANPATH}:}${_dxm_dir}"
                ;;
        esac
    done
    IFS="$_dxm_IFS_save"
fi

# --- 5. Report and export if anything changed.
if [ "$_dxm_manpath" != "$MANPATH" ]; then
    if [ "$MANPATH_SHOW_IF_MODIFIED" = "true" ] || [ "$1" = "verbose" ]; then
        printf ". MANPATH was modified: use 'showpath MAN' to display its value.\n"
    fi
    export MANPATH
fi

# --- 6. Clean up temporary variables so they don't leak into the environment.
unset _dxm_manpath _dxm_fresh_manpath _dxm_IFS_save _dxm_dir _dxm_rev

